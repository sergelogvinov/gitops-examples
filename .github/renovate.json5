{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:enableMajor",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":disableVulnerabilityAlerts",
    ":semanticCommits",
    ":semanticCommitScopeDisabled",
    "github>sergelogvinov/gitops//.github/renovate/customManagers.json5",
    "github>sergelogvinov/gitops//.github/renovate/semanticCommits.json5",
    "github>sergelogvinov/gitops//.github/renovate/groups.json5"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "prHeader": "Update Request | Renovate Bot",
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "rebaseWhen": "behind-base-branch",
  "ignorePaths": [
    "**/secrets.*",
    "**/secrets/*.ya?ml"
  ],
  "github-actions": {
    "enabled": true,
    "pinDigests": true
  },
  "flux": {
    "fileMatch": [
      "(^|/)apps/.+\\.ya?ml(?:\\.j2)?$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "(^|/)apps/.+\\.ya?ml(?:\\.j2)?$",
      "(^|/)clusters/.+/vars/.+\\.ya?ml$"
    ]
  },
  "helmfile": {
    "fileMatch": [
      "(^|/)helmfile\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "(^|/)apps/.+\\.ya?ml(?:\\.j2)?$"
    ]
  },
  "kustomize": {
    "fileMatch": [
      "(^|/)kustomization\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackagePrefixes": [
        "mcr.microsoft.com/oss/v2/kubernetes-csi/"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "helm",
        "helmfile"
      ],
      "matchPackagePatterns": [
        "cert-manager"
      ],
      "major": {
        "enabled": false
      },
      "minor": {
        "enabled": false
      }
    }
  ]
}